# Backend CortadorLive — variáveis de ambiente
# Copie este arquivo para .env e preencha com seus valores

# n8n
N8N_BASE_URL=http://localhost:5678
N8N_WEBHOOK_ANALISE=seu-webhook-id-aqui
N8N_WEBHOOK_METADADOS=seu-webhook-id-aqui

# Gemini (para thumbnails)
GEMINI_API_KEY=

# Paths (relativos ao container ou ao diretório backend/)
PROJETOS_DIR=./projetos
ASSETS_DIR=./assets
